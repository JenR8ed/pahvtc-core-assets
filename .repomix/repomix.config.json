{
  "output": {
    "filePath": ".repomix/output.xml",
    "style": "xml",
    "headerText": "PAHVTC Core Assets Repository — AI Context Pack\nPan Afrikan Heritage & Vocational Training Center\nGenerated by Repomix for AI-assisted grant writing, curriculum development, and program planning.",
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": true,
    "copyToClipboard": false
  },
  "include": [
    "core-identity/**",
    "grants/**",
    "curriculum/**",
    "assets-infrastructure/**",
    "partnerships/**",
    "README.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".repomix/output.xml",
      "**/*.pdf",
      "**/*.docx",
      "**/*.xlsx",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg"
    ]
  },
  "security": {
    "enableSecretDetection": true
  }
}
